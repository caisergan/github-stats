# Copy to .env for local dev (loaded by godotenv).
ADDR=:8080
DATABASE_PATH=app.db
BASE_URL=http://localhost:8080
# Frontend (Vite) dev-server port — read by web/vite.config.ts. Default 5175.
WEB_PORT=5175
GITHUB_CLIENT_ID=replace-me
GITHUB_CLIENT_SECRET=replace-me
# 32-byte key, hex-encoded (64 hex chars). REQUIRED — generate: openssl rand -hex 32
ENCRYPTION_KEY=
